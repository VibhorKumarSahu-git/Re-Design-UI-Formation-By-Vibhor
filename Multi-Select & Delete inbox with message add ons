<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Inbox</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    body {
      background: #000;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display',
                   'SF Pro Text', 'Helvetica Neue', sans-serif;
    }

    /* ── Phone Shell ── */
    .phone-shell {
      width: 393px;
      height: 852px;
      background: #111;
      border-radius: 54px;
      border: 1px solid #2a2a2a;
      box-shadow:
        0 0 0 1px #000,
        0 40px 120px rgba(0,0,0,.9),
        inset 0 1px 1px rgba(255,255,255,.08);
      overflow: hidden;
      position: relative;
      display: flex;
      flex-direction: column;
    }

    /* Dynamic Island */
    .dynamic-island {
      position: absolute;
      top: 14px;
      left: 50%;
      transform: translateX(-50%);
      width: 126px;
      height: 37px;
      background: #000;
      border-radius: 20px;
      z-index: 100;
    }

    /* ── Screen ── */
    .screen {
      flex: 1;
      display: flex;
      flex-direction: column;
      background: #111;
      overflow: hidden;
      position: relative;
    }

    /* ── Status Bar ── */
    .status-bar {
      height: 59px;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      padding: 0 28px 10px;
      flex-shrink: 0;
    }

    .status-time {
      font-size: 15px;
      font-weight: 600;
      color: #fff;
      letter-spacing: -0.3px;
    }

    .status-icons {
      display: flex;
      align-items: center;
      gap: 7px;
    }

    .status-icons svg {
      fill: #fff;
    }

    /* ── Header ── */
    .header {
      padding: 8px 20px 0;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      flex-shrink: 0;
    }

    .header-title {
      font-size: 34px;
      font-weight: 700;
      color: #fff;
      letter-spacing: -0.5px;
      transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
    }

    .trash-btn {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: transparent;
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.25s cubic-bezier(0.34,1.56,0.64,1);
      transform: scale(0);
      opacity: 0;
    }

    .trash-btn.visible {
      transform: scale(1);
      opacity: 1;
    }

    .trash-btn.active-state {
      background: rgba(255,255,255,.15);
    }

    .trash-btn svg {
      fill: #fff;
    }

    /* ── Divider ── */
    .divider {
      height: 1px;
      background: rgba(255,255,255,.1);
      margin: 14px 20px 0;
      flex-shrink: 0;
    }

    /* ── List ── */
    .inbox-list {
      flex: 1;
      overflow-y: auto;
      overflow-x: hidden;
      scrollbar-width: none;
    }

    .inbox-list::-webkit-scrollbar { display: none; }

    /* ── Inbox Item ── */
    .inbox-item {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      padding: 18px 20px;
      border-bottom: 1px solid rgba(255,255,255,.08);
      cursor: pointer;
      position: relative;
      transform-origin: center;
      transition:
        background 0.15s ease,
        opacity 0.4s cubic-bezier(0.4,0,0.2,1),
        transform 0.4s cubic-bezier(0.4,0,0.2,1),
        max-height 0.4s cubic-bezier(0.4,0,0.2,1);
      max-height: 200px;
      overflow: hidden;
    }

    .inbox-item:active {
      background: rgba(255,255,255,.05);
    }

    .inbox-item.selected {
      background: rgba(255,255,255,.04);
    }

    .inbox-item.removing {
      opacity: 0;
      transform: translateX(-30px) scale(0.95);
      max-height: 0;
      padding-top: 0;
      padding-bottom: 0;
      border-bottom-color: transparent;
    }

    /* Edit modal overlay for item */
    .item-content {
      flex: 1;
      padding-right: 16px;
    }

    .item-title {
      font-size: 17px;
      font-weight: 600;
      color: #fff;
      line-height: 1.3;
      margin-bottom: 5px;
      letter-spacing: -0.2px;
    }

    .item-body {
      font-size: 14px;
      color: rgba(255,255,255,.45);
      line-height: 1.5;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    /* ── Checkbox ── */
    .custom-checkbox {
      width: 26px;
      height: 26px;
      border-radius: 6px;
      border: 2px solid rgba(255,255,255,.3);
      background: rgba(255,255,255,.06);
      flex-shrink: 0;
      margin-top: 2px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s cubic-bezier(0.34,1.56,0.64,1);
      position: relative;
      overflow: hidden;
    }

    .custom-checkbox::before {
      content: '';
      position: absolute;
      inset: 0;
      background: #2196F3;
      transform: scale(0);
      border-radius: 4px;
      transition: transform 0.2s cubic-bezier(0.34,1.56,0.64,1);
    }

    .custom-checkbox.checked::before {
      transform: scale(1);
    }

    .custom-checkbox svg {
      position: relative;
      z-index: 1;
      opacity: 0;
      transform: scale(0) rotate(-10deg);
      transition: all 0.2s cubic-bezier(0.34,1.56,0.64,1) 0.05s;
    }

    .custom-checkbox.checked svg {
      opacity: 1;
      transform: scale(1) rotate(0deg);
    }

    .custom-checkbox.checked {
      border-color: #2196F3;
    }

    /* ── Home Indicator ── */
    .home-indicator {
      height: 34px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .home-bar {
      width: 134px;
      height: 5px;
      background: rgba(255,255,255,.3);
      border-radius: 3px;
    }

    /* ── Modal Overlay ── */
    .modal-overlay {
      position: absolute;
      inset: 0;
      background: rgba(180,20,20,0.45);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      z-index: 200;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
      border-radius: 54px;
    }

    .modal-overlay.show {
      opacity: 1;
      pointer-events: all;
    }

    .modal-content {
      text-align: center;
      padding: 0 40px;
      transform: scale(0.85) translateY(20px);
      transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1);
    }

    .modal-overlay.show .modal-content {
      transform: scale(1) translateY(0);
    }

    .modal-count {
      font-size: 28px;
      font-weight: 700;
      color: #fff;
      margin-bottom: 12px;
      letter-spacing: -0.5px;
    }

    .modal-text {
      font-size: 16px;
      color: rgba(255,255,255,.8);
      line-height: 1.5;
      margin-bottom: 36px;
    }

    .modal-delete-btn {
      background: #fff;
      color: #1a1a1a;
      border: none;
      border-radius: 999px;
      padding: 16px 60px;
      font-size: 18px;
      font-weight: 600;
      font-family: inherit;
      cursor: pointer;
      display: block;
      margin: 0 auto 20px;
      transition: transform 0.15s cubic-bezier(0.34,1.56,0.64,1),
                  background 0.15s ease;
      letter-spacing: -0.2px;
    }

    .modal-delete-btn:active {
      transform: scale(0.95);
      background: rgba(255,255,255,.85);
    }

    .modal-cancel-btn {
      background: none;
      border: none;
      color: #fff;
      font-size: 17px;
      font-weight: 500;
      font-family: inherit;
      cursor: pointer;
      padding: 10px 30px;
      transition: opacity 0.15s ease;
    }

    .modal-cancel-btn:active {
      opacity: 0.6;
    }

    /* ── Edit Modal ── */
    .edit-overlay {
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,0.75);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      z-index: 200;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
      border-radius: 54px;
      padding-bottom: 50px;
    }

    .edit-overlay.show {
      opacity: 1;
      pointer-events: all;
    }

    .edit-sheet {
      background: #1c1c1e;
      border-radius: 16px;
      width: calc(100% - 32px);
      overflow: hidden;
      transform: translateY(40px);
      transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1);
      border: 1px solid rgba(255,255,255,.1);
    }

    .edit-overlay.show .edit-sheet {
      transform: translateY(0);
    }

    .edit-sheet-title {
      font-size: 13px;
      font-weight: 500;
      color: rgba(255,255,255,.4);
      text-align: center;
      padding: 12px 16px 8px;
      letter-spacing: 0.2px;
    }

    .edit-field-label {
      font-size: 12px;
      color: rgba(255,255,255,.4);
      padding: 8px 16px 2px;
    }

    .edit-field {
      width: 100%;
      background: transparent;
      border: none;
      border-bottom: 1px solid rgba(255,255,255,.1);
      color: #fff;
      font-size: 16px;
      font-family: inherit;
      padding: 10px 16px 14px;
      outline: none;
    }

    .edit-field:last-of-type {
      border-bottom: none;
    }

    .edit-actions {
      display: flex;
      border-top: 1px solid rgba(255,255,255,.1);
    }

    .edit-btn {
      flex: 1;
      background: none;
      border: none;
      color: #2196F3;
      font-size: 17px;
      font-family: inherit;
      padding: 16px;
      cursor: pointer;
      transition: background 0.15s ease;
    }

    .edit-btn.danger {
      color: #ff453a;
    }

    .edit-btn:first-child {
      border-right: 1px solid rgba(255,255,255,.1);
    }

    .edit-btn:active {
      background: rgba(255,255,255,.08);
    }

    /* ── Empty State ── */
    .empty-state {
      display: none;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 60px 20px;
      color: rgba(255,255,255,.3);
      font-size: 16px;
      gap: 12px;
    }

    .empty-state svg {
      opacity: 0.3;
    }

    /* ── Add Button ── */
    .add-btn {
      position: absolute;
      bottom: 50px;
      right: 20px;
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: #2196F3;
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 20px rgba(33,150,243,.5);
      transition: transform 0.2s cubic-bezier(0.34,1.56,0.64,1),
                  background 0.15s ease;
      z-index: 10;
    }

    .add-btn:active {
      transform: scale(0.9);
      background: #1976D2;
    }

    /* ── Add Item Modal ── */
    .add-overlay {
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,0.75);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      z-index: 200;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
      border-radius: 54px;
      padding-bottom: 50px;
    }

    .add-overlay.show {
      opacity: 1;
      pointer-events: all;
    }

    .add-sheet {
      background: #1c1c1e;
      border-radius: 16px;
      width: calc(100% - 32px);
      overflow: hidden;
      transform: translateY(40px);
      transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1);
      border: 1px solid rgba(255,255,255,.1);
    }

    .add-overlay.show .add-sheet {
      transform: translateY(0);
    }

    /* Ripple effect */
    @keyframes ripple {
      from { transform: scale(0); opacity: 0.4; }
      to { transform: scale(4); opacity: 0; }
    }

    .ripple {
      position: absolute;
      width: 30px;
      height: 30px;
      background: rgba(255,255,255,.3);
      border-radius: 50%;
      pointer-events: none;
      animation: ripple 0.5s ease-out forwards;
      transform-origin: center;
    }

    /* Responsive for small screens */
    @media (max-width: 430px) {
      .phone-shell {
        width: 100vw;
        height: 100dvh;
        border-radius: 0;
        border: none;
        box-shadow: none;
      }

      .modal-overlay,
      .edit-overlay,
      .add-overlay {
        border-radius: 0;
      }
    }

    /* stagger animation on load */
    @keyframes slideInItem {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .inbox-item {
      animation: slideInItem 0.4s cubic-bezier(0.4,0,0.2,1) both;
    }
  </style>
</head>
<body>

<div class="phone-shell">
  <div class="dynamic-island"></div>

  <div class="screen">
    <!-- Status Bar -->
    <div class="status-bar">
      <span class="status-time" id="clock">9:41</span>
      <div class="status-icons">
        <!-- Signal -->
        <svg width="17" height="12" viewBox="0 0 17 12">
          <rect x="0" y="7" width="3" height="5" rx="1" opacity=".4"/>
          <rect x="4.5" y="5" width="3" height="7" rx="1" opacity=".6"/>
          <rect x="9" y="2.5" width="3" height="9.5" rx="1" opacity=".8"/>
          <rect x="13.5" y="0" width="3" height="12" rx="1"/>
        </svg>
        <!-- WiFi -->
        <svg width="16" height="12" viewBox="0 0 16 12" fill="none">
          <path d="M8 9.5a1.5 1.5 0 110 3 1.5 1.5 0 010-3z" fill="#fff"/>
          <path d="M3.5 6.5a6.5 6.5 0 019 0" stroke="#fff" stroke-width="1.5"
                stroke-linecap="round" opacity=".6"/>
          <path d="M1 3.5a10.5 10.5 0 0114 0" stroke="#fff" stroke-width="1.5"
                stroke-linecap="round" opacity=".4"/>
        </svg>
        <!-- Battery -->
        <svg width="25" height="12" viewBox="0 0 25 12" fill="none">
          <rect x="0.5" y="0.5" width="21" height="11" rx="3.5" stroke="#fff" stroke-opacity=".4"/>
          <rect x="2" y="2" width="16" height="8" rx="2" fill="#fff"/>
          <path d="M22.5 4v4a2 2 0 000-4z" fill="#fff" fill-opacity=".4"/>
        </svg>
      </div>
    </div>

    <!-- Header -->
    <div class="header">
      <div class="header-title" id="header-title">Inbox</div>
      <button class="trash-btn" id="trash-btn" onclick="openDeleteModal()">
        <svg width="22" height="22" viewBox="0 0 24 24">
          <path d="M9 3h6l1 2H8L9 3zm-5 3h16l-1.5 15H5.5L4 6zm5 3v9h1V9H9zm5 0v9h1V9h-1z"/>
        </svg>
      </button>
    </div>

    <div class="divider"></div>

    <!-- List -->
    <div class="inbox-list" id="inbox-list"></div>

    <!-- Empty State -->
    <div class="empty-state" id="empty-state">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="#fff">
        <path d="M20 4H4C2.9 4 2 4.9 2 6v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0
                 2-8 5-8-5h16zm0 12H4V8l8 5 8-5v10z"/>
      </svg>
      <span>No messages</span>
    </div>

    <!-- Add Button -->
    <button class="add-btn" id="add-btn" onclick="openAddModal()">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="#fff">
        <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
      </svg>
    </button>

    <!-- Home Indicator -->
    <div class="home-indicator">
      <div class="home-bar"></div>
    </div>

    <!-- ── Delete Modal ── -->
    <div class="modal-overlay" id="delete-modal">
      <div class="modal-content">
        <div class="modal-count" id="modal-count">3 items</div>
        <div class="modal-text">
          Are you sure you want to delete these<br>entries? You can't undo this action.
        </div>
        <button class="modal-delete-btn" onclick="confirmDelete()">Delete</button>
        <button class="modal-cancel-btn" onclick="closeDeleteModal()">Cancel</button>
      </div>
    </div>

    <!-- ── Edit Modal ── -->
    <div class="edit-overlay" id="edit-overlay">
      <div class="edit-sheet">
        <div class="edit-sheet-title">Edit Message</div>
        <div class="edit-field-label">Title</div>
        <input class="edit-field" id="edit-title-input" type="text" placeholder="Title"/>
        <div class="edit-field-label">Message</div>
        <textarea class="edit-field" id="edit-body-input"
                  rows="3" placeholder="Message body"
                  style="resize:none; padding-top:10px;"></textarea>
        <div class="edit-actions">
          <button class="edit-btn" onclick="cancelEdit()">Cancel</button>
          <button class="edit-btn" onclick="saveEdit()">Save</button>
        </div>
      </div>
    </div>

    <!-- ── Add Modal ── -->
    <div class="add-overlay" id="add-overlay">
      <div class="add-sheet">
        <div class="edit-sheet-title">New Message</div>
        <div class="edit-field-label">Title</div>
        <input class="edit-field" id="add-title-input" type="text" placeholder="Title"/>
        <div class="edit-field-label">Message</div>
        <textarea class="edit-field" id="add-body-input"
                  rows="3" placeholder="Message body"
                  style="resize:none; padding-top:10px;"></textarea>
        <div class="edit-actions">
          <button class="edit-btn" onclick="closeAddModal()">Cancel</button>
          <button class="edit-btn" onclick="saveAddItem()">Add</button>
        </div>
      </div>
    </div>

  </div><!-- /screen -->
</div><!-- /phone-shell -->

<script>
  /* ── Data ── */
  let items = [
    { id: 1, title: 'Weekly team update',
      body: "Hi team, Just a quick update on our progress this week. We've made significant strides in th..." },
    { id: 2, title: 'Your subscription confirmation',
      body: "Thank you for subscribing to our newsletter! You'll now receive updates about our latest..." },
    { id: 3, title: 'Invoice #1234 for April',
      body: 'Your monthly invoice is now available. Please find attached the detailed breakdown of your...' },
    { id: 4, title: 'Security alert: New login',
      body: 'We detected a new sign-in to your account from a new device or location. If this was you,...' },
    { id: 5, title: 'Upcoming maintenance notice',
      body: 'Please be advised that our platform will undergo scheduled maintenance this weeken...' },
  ];

  let selected   = new Set();
  let editingId  = null;
  let nextId     = 100;

  /* ── Clock ── */
  function updateClock() {
    const now = new Date();
    const h   = now.getHours().toString().padStart(2,'0');
    const m   = now.getMinutes().toString().padStart(2,'0');
    document.getElementById('clock').textContent = `${h}:${m}`;
  }
  updateClock();
  setInterval(updateClock, 10000);

  /* ── Render ── */
  function render() {
    const list       = document.getElementById('inbox-list');
    const emptyState = document.getElementById('empty-state');
    const trashBtn   = document.getElementById('trash-btn');

    list.innerHTML = '';

    if (items.length === 0) {
      emptyState.style.display = 'flex';
    } else {
      emptyState.style.display = 'none';
    }

    items.forEach((item, idx) => {
      const checked = selected.has(item.id);

      const el = document.createElement('div');
      el.className = 'inbox-item' + (checked ? ' selected' : '');
      el.dataset.id = item.id;
      el.style.animationDelay = (idx * 0.06) + 's';

      el.innerHTML = `
        <div class="item-content">
          <div class="item-title">${escHtml(item.title)}</div>
          <div class="item-body">${escHtml(item.body)}</div>
        </div>
        <div class="custom-checkbox ${checked ? 'checked' : ''}" data-id="${item.id}">
          <svg width="14" height="11" viewBox="0 0 14 11" fill="none">
            <path d="M1.5 5.5L5.5 9.5L12.5 1.5"
                  stroke="#fff" stroke-width="2.2"
                  stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      `;

      /* Checkbox click */
      el.querySelector('.custom-checkbox').addEventListener('click', e => {
        e.stopPropagation();
        toggleSelect(item.id);
      });

      /* Row tap → edit */
      el.querySelector('.item-content').addEventListener('click', () => {
        openEditModal(item.id);
      });

      list.appendChild(el);
    });

    /* Trash icon */
    if (selected.size > 0) {
      trashBtn.classList.add('visible');
    } else {
      trashBtn.classList.remove('visible');
    }
  }

  function escHtml(str) {
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  /* ── Select ── */
  function toggleSelect(id) {
    if (selected.has(id)) {
      selected.delete(id);
    } else {
      selected.add(id);
    }
    render();
  }

  /* ── Delete Modal ── */
  function openDeleteModal() {
    const n     = selected.size;
    const label = n === 1 ? '1 item' : `${n} items`;
    document.getElementById('modal-count').textContent = label;
    document.getElementById('delete-modal').classList.add('show');
  }

  function closeDeleteModal() {
    document.getElementById('delete-modal').classList.remove('show');
  }

  function confirmDelete() {
    closeDeleteModal();

    /* Animate items out one by one, then remove from data */
    selected.forEach(id => {
      const el = document.querySelector(`.inbox-item[data-id="${id}"]`);
      if (el) el.classList.add('removing');
    });

    setTimeout(() => {
      items    = items.filter(i => !selected.has(i.id));
      selected = new Set();
      render();
    }, 420);
  }

  /* ── Edit Modal ── */
  function openEditModal(id) {
    editingId = id;
    const item = items.find(i => i.id === id);
    if (!item) return;
    document.getElementById('edit-title-input').value = item.title;
    document.getElementById('edit-body-input').value  = item.body;
    document.getElementById('edit-overlay').classList.add('show');
  }

  function cancelEdit() {
    editingId = null;
    document.getElementById('edit-overlay').classList.remove('show');
  }

  function saveEdit() {
    if (!editingId) return;
    const title = document.getElementById('edit-title-input').value.trim();
    const body  = document.getElementById('edit-body-input').value.trim();
    if (!title) return;

    items = items.map(i =>
      i.id === editingId
        ? { ...i, title, body }
        : i
    );
    editingId = null;
    document.getElementById('edit-overlay').classList.remove('show');
    render();
  }

  /* ── Add Modal ── */
  function openAddModal() {
    document.getElementById('add-title-input').value = '';
    document.getElementById('add-body-input').value  = '';
    document.getElementById('add-overlay').classList.add('show');
  }

  function closeAddModal() {
    document.getElementById('add-overlay').classList.remove('show');
  }

  function saveAddItem() {
    const title = document.getElementById('add-title-input').value.trim();
    const body  = document.getElementById('add-body-input').value.trim();
    if (!title) return;

    items.unshift({ id: nextId++, title, body: body || 'No preview available.' });
    closeAddModal();
    render();
  }

  /* ── Close modals on overlay click ── */
  document.getElementById('edit-overlay').addEventListener('click', function(e) {
    if (e.target === this) cancelEdit();
  });
  document.getElementById('add-overlay').addEventListener('click', function(e) {
    if (e.target === this) closeAddModal();
  });
  document.getElementById('delete-modal').addEventListener('click', function(e) {
    if (e.target === this) closeDeleteModal();
  });

  /* ── Init ── */
  render();
</script>
</body>
</html>
