.nft-price { font-size:0.71rem; font-weight:600; color:var(--accent3); }
.nft-id { font-size:0.59rem; color:#333; }

/* LIST VIEW */
.list-stack { display:flex; flex-direction:column; gap:8px; }
.list-row {
  display:flex; align-items:center; gap:13px;
  background:#0d0d10; border:1px solid #1a1a1e;
