}
.pack-img:nth-child(1) { top:0; left:8px; transform:rotate(-7deg); z-index:2; }
.pack-img:nth-child(2) { top:12px; left:0; transform:rotate(5deg); z-index:1; filter:brightness(0.6) saturate(0.75); }

.pack-stack:hover .pack-img:nth-child(1) { transform:rotate(-14deg) translateY(-18px) translateX(5px); box-shadow:0 22px 50px rgba(0,0,0,0.65); }
.pack-stack:hover .pack-img:nth-child(2) { transform:rotate(11deg) translateY(14px) translateX(-5px); filter:brightness(0.78) saturate(0.9); }
.pack-stack:active .pack-img { transform:scale(0.94) !important; }

.pack-glow {
