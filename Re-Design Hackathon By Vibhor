<script>
let sel = 0;
function toggleRow(el) {
  el.style.transform = 'scale(0.97)';
  setTimeout(() => el.style.transform = '', 120);
  el.classList.toggle('selected');
  sel = document.querySelectorAll('.inbox-row.selected').length;
  document.getElementById('selN').textContent = sel;
  const btn = document.getElementById('delBtn');
  sel > 0 ? btn.classList.add('show') : btn.classList.remove('show');
}

function openModal() {
  document.getElementById('modalN').textContent = sel + (sel === 1 ? ' item' : ' items');
  document.getElementById('modalBg').classList.add('open');
}

function closeModal() {
  const bg = document.getElementById('modalBg');
  const sh = bg.querySelector('.modal-sheet');
  sh.style.transition = 'transform 0.3s cubic-bezier(0.55,0,1,0.45), opacity 0.25s';
  sh.style.transform = 'translateY(110%) scale(0.94)';
  sh.style.opacity = '0';
  setTimeout(() => {
    bg.classList.remove('open');
    sh.style.cssText = '';
  }, 300);
}

function confirmDelete() {
  document.querySelectorAll('.inbox-row.selected').forEach((r, i) => {
    setTimeout(() => {
      r.classList.add('row-exit');
      setTimeout(() => r.remove(), 430);
    }, i * 65);
  });
  sel = 0;
  document.getElementById('selN').textContent = '0';
  document.getElementById('delBtn').classList.remove('show');
  closeModal();
  setTimeout(() => {
    const badge = document.getElementById('ibadge');
    badge.textContent = document.querySelectorAll('.inbox-row').length;
    badge.style.transform = 'scale(1.35)';
    badge.style.transition = 'transform 0.35s cubic-bezier(0.34,1.56,0.64,1)';
    setTimeout(() => badge.style.cssText = '', 350);
  }, 520);
}

document.getElementById('modalBg').addEventListener('click', e => { if(e.target.id==='modalBg') closeModal(); });

function switchTab(view, btn) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.vtab').forEach(t => t.classList.remove('active'));
  document.getElementById('p-' + view).classList.add('active');
  btn.classList.add('active');
  btn.style.transform = 'scale(1.1)';
  setTimeout(() => btn.style.transform = '', 220);
}
</script>
