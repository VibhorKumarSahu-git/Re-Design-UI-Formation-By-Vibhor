.list-price { font-size:0.77rem; font-weight:600; color:var(--accent3); }
.list-id { font-size:0.6rem; color:#333; margin-top:3px; }

/* PACK VIEW */
.pack-wrap { display:flex; flex-direction:column; align-items:center; gap:22px; padding:8px 0; }

.pack-stack {
  position:relative; width:150px; height:155px; cursor:pointer;
}
.pack-img {
  position:absolute; width:140px; height:140px;
